# .graphifyignore — controls what `/graphify` scans into the knowledge graph.
#
# graphify reads ONE ignore file per directory: if a directory has a
# .graphifyignore it is used INSTEAD of that directory's .gitignore (they are
# not merged). So this root file must be a SUPERSET of the root .gitignore —
# every pattern below the divider mirrors .gitignore so we don't suddenly start
# scanning node_modules/, venvs, runtime data, etc. — plus the graphify-only
# exclusions at the bottom for generated/binary CI artifacts that add noise
# nodes (Playwright pixel-baseline snapshots, MCP screenshots) and the graph's
# own output directory.
#
# Keep the mirrored section in sync with .gitignore when that file changes.

# ───────────────────────── mirrors .gitignore ─────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# SQLite databases (runtime data)
*.db
*.db-wal
*.db-shm
# Exception: test fixtures and bundled databases
!tests/fixtures/*.db
!bundles/*.db

# Environment & secrets
.env
.env.*
credentials.json

# OS
.DS_Store
Thumbs.db

# Yeliztli runtime data (not curated panels)
data/
!backend/data/
!backend/data/**
# ...but never the build artifacts the broad negation above would otherwise re-include
backend/data/**/__pycache__/
downloads/
.yeliztli/
logs/

# Coverage & test artifacts
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
# Stringified MagicMock leaks (defense-in-depth — fix the test, but don't commit the artifact)
<MagicMock*

# Playwright
test-results/
playwright-report/
blob-report/

# Documentation site (MkDocs build output — published via CI, never committed)
/site/

# AI
.claude/
.codex/
CLAUDE.md
AGENTS.md

# Review/planning docs (local only — kept on disk, never committed)
gero.md
/amv2.md
/stup.md
/prd.md
/Yeliztli_Spec.md
/docs/AncestryDNA_Implementation_Steps.md
/docs/AncestryDNA_Integration_Plan.md
/docs/bundle-v2.0.0-build-plan.md
/docs/bundle-v2.0.0-implementation-steps.md

# Real user genotype exports — never commit (privacy + size)
AncestryDNA.txt
AncestryDNA.txt:Zone.Identifier
AncestryDNAsample.txt
AncestryDNAsample.txt:Zone.Identifier

# LAI bundle artifacts — distributed via GitHub Releases, not git. The legacy
# pre-rebrand bundle tarball is a binary archive graphify never scans, so it
# needs no pattern here; omitting its name also keeps this file free of rebrand
# residuals (see tests/backend/test_rename_guard.py).
yeliztli_lai_bundle_*.tar.gz
lai_bundle_build/

# ─────────────────── graphify-only exclusions ───────────────────
# These are NOT in .gitignore (the files are tracked in git) but must stay out
# of the knowledge graph: they are generated/binary artifacts whose only effect
# on the graph is noise — vision extraction over pixel-diff baselines, MCP
# screenshots — or the graph's own output.

# graphify's own output — never graph the graph.
graphify-out/

# Playwright visual-regression baselines (binary PNGs, e.g.
# tests/e2e/cross-browser.spec.ts-snapshots/). Tracked in git as test fixtures
# but meaningless as graph nodes.
*-snapshots/

# Ad-hoc MCP / Playwright screenshot + output scratch dirs.
/.playwright-mcp/
/screenshots/
/output/
